{
  "name": "badock",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "description": "BadocK local-first ADOC monorepo.",
  "license": "MIT",
  "engines": {
    "node": ">=22.5 <25"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "cli": "pnpm --filter @badock/cli badock",
    "badock": "pnpm --filter @badock/cli badock",
    "badock:scan": "pnpm --filter @badock/cli badock project scan-report .",
    "badock:issue:new": "pnpm --filter @badock/cli badock issue-file new .",
    "badock:issue:list": "pnpm --filter @badock/cli badock issue-file list .",
    "badock:issue:show": "pnpm --filter @badock/cli badock issue-file show .",
    "badock:issue:validate": "pnpm --filter @badock/cli badock issue-file validate .",
    "agents:doctor": "pnpm --filter @badock/cli badock doctor .",
    "agents:issue": "pnpm --filter @badock/cli badock agents issue .",
    "agents:run": "pnpm --filter @badock/cli badock agents run .",
    "badock:review-run": "pnpm --filter @badock/cli badock review-run .",
    "badock:commit-run": "pnpm --filter @badock/cli badock commit-run .",
    "badock:push-run": "pnpm --filter @badock/cli badock push-run .",
    "agents:pr": "pnpm --filter @badock/cli badock agents pr .",
    "runs:smoke": "pnpm --filter @badock/core build && node packages/core/dist/run-report-smoke.js",
    "runs:validate": "pnpm --filter @badock/core build && node packages/core/dist/validate-runs.js",
    "badock:github:issues": "pnpm --filter @badock/cli badock github issues .",
    "badock:github:publish-issue": "pnpm --filter @badock/cli badock github publish-issue ."
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "typescript": "5.8.3"
  }
}
