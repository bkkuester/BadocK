{
  "schemaVersion": 1,
  "project": {
    "name": "BadocK",
    "productName": "BadocK",
    "type": "adoc",
    "description": "Local-first ADOC MVP",
    "root": "."
  },
  "stack": {
    "languages": ["typescript"],
    "runtime": "node",
    "packageManager": "pnpm",
    "frameworks": [],
    "testCommands": ["corepack pnpm test"],
    "buildCommands": ["corepack pnpm build"]
  },
  "vcs": {
    "type": "git",
    "defaultBranch": "main",
    "worktreeBaseDir": "../worktrees",
    "allowMainExecution": false
  },
  "github": {
    "enabled": true,
    "owner": "bkkuester",
    "repo": "BadocK",
    "issues": true,
    "pullRequests": true
  },
  "providers": [
    {
      "id": "codex-cli",
      "type": "local-process",
      "defaultModel": "unknown",
      "parameters": {
        "program": "codex",
        "stdin": true
      }
    },
    {
      "id": "mock",
      "type": "mock",
      "defaultModel": "mock-planner",
      "parameters": {
        "temperature": 0
      }
    }
  ],
  "agents": {
    "registryFile": ".badock/agents.json",
    "defaultSelectionMode": "explicit",
    "profiles": [
      {
        "id": "ci-agent",
        "role": "ci",
        "provider": "codex-cli",
        "model": "unknown",
        "permissionMode": "manual",
        "capabilities": ["typecheck", "test", "build", "core-hardening"],
        "labels": ["ci-agent"],
        "paths": ["apps/**", "packages/**", "README.md", "AGENTS.md", "package.json"]
      },
      {
        "id": "orchestration-agent",
        "role": "orchestration",
        "provider": "codex-cli",
        "model": "unknown",
        "permissionMode": "manual",
        "capabilities": ["run-orchestration", "worktree", "review"],
        "labels": ["orchestration-agent"],
        "paths": ["apps/**", "packages/**", ".badock/project.json", "README.md"]
      }
    ]
  },
  "permissions": {
    "mode": "manual",
    "defaultMode": "manual",
    "allowCommit": false,
    "allowPush": false,
    "allowOpenPr": false,
    "allowPullRequest": false,
    "allowInstallDependencies": false,
    "allowDependencyInstall": false,
    "allowModifySecrets": false,
    "allowSecretChanges": false,
    "allowMainExecution": false,
    "allowNetwork": false,
    "allowedCommands": [
      "corepack pnpm agents:doctor",
      "corepack pnpm typecheck",
      "corepack pnpm test",
      "corepack pnpm build",
      "git status",
      "git diff",
      "codex exec -"
    ],
    "allowCommands": [
      "corepack pnpm agents:doctor",
      "corepack pnpm typecheck",
      "corepack pnpm test",
      "corepack pnpm build",
      "git status",
      "git diff",
      "codex exec -"
    ],
    "sensitiveFiles": [".env", ".env.*"]
  },
  "runs": {
    "directory": ".badock/runs",
    "ignoreRunArtifactsInGit": true
  },
  "cost": {
    "tracking": "estimated",
    "currency": "USD",
    "budgetPerRun": null
  }
}
